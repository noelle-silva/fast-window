{
  "schemaVersion": 2,
  "id": "folders",
  "name": "收藏集",
  "description": "收藏集 v5 应用，支持收藏文件夹、网址、文件、分组与桌面视图",
  "versionSource": "src-tauri/tauri.conf.json",
  "profiles": {
    "release": {
      "build": { "command": "pnpm", "args": ["tauri", "build", "--no-bundle"] },
      "stageDir": "dist-app/v5-windows",
      "files": [
        { "from": "src-tauri/target/release/folders.exe", "to": "folders.exe" },
        { "from": "src-tauri/target/release/folders-backend.exe", "to": "folders-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    },
    "dev": {
      "build": { "command": "pnpm", "args": ["build:exe:dev"] },
      "stageDir": "dist-app/v5-windows-dev",
      "files": [
        { "from": "src-tauri/target/debug/folders.exe", "to": "folders.exe" },
        { "from": "src-tauri/target/debug/folders-backend.exe", "to": "folders-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    }
  },
  "package": {
    "windowsExecutable": "folders.exe",
    "icon": "assets/icon.svg"
  },
  "displayMode": "default",
  "commands": [
    { "id": "open-settings", "title": "打开收藏集设置" },
    { "id": "add-folder", "title": "添加收藏文件夹" },
    { "id": "open-folders", "title": "打开收藏集" }
  ]
}
