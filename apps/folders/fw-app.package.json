{
  "schemaVersion": 1,
  "id": "folders",
  "name": "文件夹收藏",
  "description": "文件夹收藏 v5 应用，支持收藏文件夹、分组与桌面视图",
  "versionSource": "src-tauri/tauri.conf.json",
  "build": {
    "command": "pnpm",
    "args": ["tauri", "build", "--no-bundle"]
  },
  "package": {
    "windowsExecutable": "folders.exe",
    "icon": "assets/icon.svg",
    "files": [
      { "from": "src-tauri/target/release/folders.exe", "to": "folders.exe" },
      { "from": "src-tauri/target/release/folders-backend.exe", "to": "folders-backend.exe" },
      { "from": "src-tauri/target/resources/assets", "to": "assets" }
    ]
  },
  "catalogIcon": { "type": "emoji", "value": "📁" },
  "displayMode": "default",
  "commands": [
    { "id": "open-settings", "title": "打开文件夹收藏设置" },
    { "id": "add-folder", "title": "添加收藏文件夹" },
    { "id": "open-folders", "title": "打开文件夹收藏" }
  ]
}
