{
  "name": "@fast-window/app-bookmarks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:backend": "node scripts/build-backend.mjs",
    "build:backend:sidecar": "pnpm build:backend && node scripts/build-backend-sidecar.mjs",
    "build:resources": "node scripts/build-resources.mjs",
    "build:exe": "pnpm build:backend:sidecar && pnpm tauri build",
    "build:exe:dev": "cargo build --manifest-path src-tauri/Cargo.toml",
    "build:ui": "pnpm build:backend && vite build && pnpm build:resources",
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "postject": "1.0.0-alpha.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
