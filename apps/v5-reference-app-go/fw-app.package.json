{
  "schemaVersion": 2,
  "id": "v5-reference-app-go",
  "name": "v5 Reference App Go",
  "description": "Fast Window v5 Go sidecar 模范应用",
  "versionSource": "src-tauri/tauri.conf.json",
  "profiles": {
    "release": {
      "build": { "command": "pnpm", "args": ["tauri", "build", "--no-bundle"] },
      "stageDir": "dist-app/v5-windows",
      "files": [
        { "from": "src-tauri/target/release/v5-reference-app-go.exe", "to": "v5-reference-app-go.exe" },
        { "from": "src-tauri/target/release/v5-reference-app-go-backend.exe", "to": "v5-reference-app-go-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    },
    "dev": {
      "build": { "command": "pnpm", "args": ["build:exe:dev"] },
      "stageDir": "dist-app/v5-windows-dev",
      "files": [
        { "from": "src-tauri/target/debug/v5-reference-app-go.exe", "to": "v5-reference-app-go.exe" },
        { "from": "src-tauri/target/debug/v5-reference-app-go-backend.exe", "to": "v5-reference-app-go-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    }
  },
  "package": {
    "windowsExecutable": "v5-reference-app-go.exe",
    "icon": "assets/icon.svg"
  },
  "displayMode": "default",
  "commands": [
    { "id": "open-reference", "title": "打开 v5 Go 模范 App" },
    { "id": "show-health", "title": "查看模范 App 健康状态" },
    { "id": "edit-settings", "title": "编辑模范 App 设置" }
  ]
}
