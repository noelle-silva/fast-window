{
  "schemaVersion": 2,
  "id": "ai-draw",
  "name": "AI Draw",
  "description": "AI 绘图 v5 应用，支持绘图供应商与设置入口",
  "versionSource": "src-tauri/tauri.conf.json",
  "profiles": {
    "release": {
      "build": { "command": "pnpm", "args": ["tauri", "build", "--no-bundle"] },
      "stageDir": "dist-app/v5-windows",
      "files": [
        { "from": "src-tauri/target/release/ai-draw-app.exe", "to": "ai-draw-app.exe" },
        { "from": "src-tauri/target/release/ai-draw-backend.exe", "to": "ai-draw-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    },
    "dev": {
      "build": { "command": "pnpm", "args": ["build:exe:dev"] },
      "stageDir": "dist-app/v5-windows-dev",
      "files": [
        { "from": "src-tauri/target/debug/ai-draw-app.exe", "to": "ai-draw-app.exe" },
        { "from": "src-tauri/target/debug/ai-draw-backend.exe", "to": "ai-draw-backend.exe" },
        { "from": "src-tauri/target/resources/assets", "to": "assets" }
      ]
    }
  },
  "package": {
    "windowsExecutable": "ai-draw-app.exe",
    "icon": "assets/icon.svg"
  },
  "catalogIcon": { "type": "emoji", "value": "🎨" },
  "displayMode": "default",
  "commands": [
    { "id": "open-settings", "title": "打开设置" },
    { "id": "provider-settings", "title": "绘图供应商设置" }
  ]
}
