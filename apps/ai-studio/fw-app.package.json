{
  "schemaVersion": 1,
  "id": "ai-studio",
  "name": "AI Studio",
  "description": "多供应商与角色系统的 v5 AI Studio 应用",
  "versionSource": "src-tauri/tauri.conf.json",
  "build": {
    "command": "pnpm",
    "args": ["tauri", "build", "--no-bundle"]
  },
  "package": {
    "windowsExecutable": "ai-studio-app.exe",
    "icon": "assets/icon.svg",
    "files": [
      { "from": "src-tauri/target/release/ai-studio-app.exe", "to": "ai-studio-app.exe" },
      { "from": "src-tauri/target/release/ai-studio-backend.exe", "to": "ai-studio-backend.exe" },
      { "from": "src-tauri/target/resources/assets", "to": "assets" }
    ]
  },
  "catalogIcon": { "type": "emoji", "value": "🧠" },
  "displayMode": "default",
  "commands": [
    { "id": "new-chat", "title": "新建对话" },
    { "id": "open-studio", "title": "打开 AI Studio" },
    { "id": "provider-settings", "title": "模型提供商设置" },
    { "id": "open-settings", "title": "打开设置" }
  ]
}
