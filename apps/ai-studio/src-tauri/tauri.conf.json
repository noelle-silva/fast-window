{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Studio",
  "version": "0.1.0",
  "identifier": "com.fastwindow.aistudio",
  "build": {
    "beforeDevCommand": "pnpm build:backend && pnpm build:resources && pnpm dev",
    "devUrl": "http://localhost:1431",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Studio",
        "width": 980,
        "height": 680,
        "decorations": false,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ai-studio-backend"
    ],
    "resources": {
      "../assets/": "assets"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
