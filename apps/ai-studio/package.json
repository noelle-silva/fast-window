{
  "name": "@fast-window/app-ai-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:backend": "node scripts/build-backend.mjs",
    "build:resources": "node scripts/build-resources.mjs",
    "build:exe": "pnpm build:backend && pnpm tauri build",
    "build:exe:dev": "pnpm build:backend && cargo build --manifest-path src-tauri/Cargo.toml",
    "build:ui": "vite build && pnpm build:resources",
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@noelle-silva/eucli-aitoolcall-sdk": "^0.1.6",
    "@tauri-apps/api": "^2.11.0",
    "dompurify": "^3.0.11",
    "jszip": "^3.10.1",
    "katex": "^0.16.11",
    "mammoth": "^1.10.0",
    "marked": "^12.0.2",
    "mermaid": "^10.9.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
