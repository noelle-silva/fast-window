{
  "name": "@fast-window/app-hypercortex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:backend": "node scripts/build-backend.mjs",
    "build:resources": "node scripts/build-resources.mjs",
    "build:exe": "pnpm build:backend && pnpm tauri build",
    "build:exe:dev": "pnpm build:backend && cargo build --manifest-path src-tauri/Cargo.toml",
    "build:ui": "vite build && pnpm build:resources",
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "codemirror": "^6.0.2",
    "dompurify": "^3.0.11",
    "katex": "^0.16.11",
    "mammoth": "^1.12.0",
    "marked": "^12.0.2",
    "mermaid": "^10.9.1",
    "muuri": "^0.9.5",
    "pdfjs-dist": "^5.6.205",
    "plyr": "^3.8.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@tauri-apps/api": "^2.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
