{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quick Bar",
  "version": "0.1.0",
  "identifier": "com.fastwindow.quickbar",
  "build": {
    "beforeDevCommand": "pnpm build:backend && pnpm build:resources && pnpm dev",
    "devUrl": "http://127.0.0.1:1435",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quick Bar",
        "width": 920,
        "height": 620,
        "decorations": false,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/quick-bar-backend"
    ],
    "resources": {
      "../assets/": "assets"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
