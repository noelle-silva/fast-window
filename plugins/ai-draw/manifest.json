{
  "id": "ai-draw",
  "name": "AI 绘图",
  "author": "fast-window",
  "version": "1.2.2",
  "description": "左侧输入提示词，右侧出图；一次请求一次返回（无上下文）；默认保存到 data/ai-draw/output-images，可通过资源管理器选择输出目录",
  "main": "index.js",
  "background": { "autoStart": true },
  "icon": "svg:icon.svg",
  "keyword": "ai",
  "apiVersion": 2,
  "ui": { "type": "iframe" },
  "requires": [
    "storage.get",
    "storage.set",
    "storage.remove",
    "ui.showToast",
    "ui.startDragging",
    "net.request",
    "task.get",
    "task.list",
    "task.cancel",
    "clipboard.writeImage",
    "clipboard.writeText",
    "files.getOutputDir",
    "files.pickOutputDir",
    "files.openOutputDir",
    "files.images.writeBase64",
    "files.images.read",
    "files.images.list",
    "files.images.delete",
    "files.pickImages"
  ]
}
