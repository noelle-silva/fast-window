{
  "id": "ai-draw",
  "name": "AI 绘图",
  "author": "fast-window",
  "version": "1.2.3",
  "description": "左侧输入提示词，右侧出图；一次请求一次返回（无上下文）；默认保存到 data/ai-draw/output-images，可通过资源管理器选择输出目录",
  "main": "index.js",
  "background": {
    "autoStart": true
  },
  "icon": "svg:icon.svg",
  "keyword": "ai",
  "apiVersion": 2,
  "ui": {
    "type": "iframe"
  },
  "requires": [
    "tauri:plugin_files_list_dir",
    "tauri:plugin_files_read_text",
    "tauri:plugin_files_write_text",
    "tauri:plugin_files_delete",
    "tauri:http_request",
    "tauri:task_create",
    "tauri:task_get",
    "tauri:task_list",
    "tauri:task_cancel",
    "tauri:plugin_get_output_dir",
    "tauri:plugin_pick_output_dir",
    "tauri:plugin_open_output_dir",
    "tauri:plugin_pick_images",
    "tauri:plugin_images_write_base64",
    "tauri:plugin_images_read",
    "tauri:plugin_images_list",
    "tauri:plugin_images_delete",
    "tauri:plugin:window|start_dragging",
    "tauri:plugin:clipboard-manager|write_text",
    "tauri:clipboard_write_image_data_url"
  ]
}
