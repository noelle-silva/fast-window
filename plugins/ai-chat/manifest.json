{
  "id": "ai-chat",
  "name": "AI 聊天",
  "author": "fast-window",
  "version": "1.0.2",
  "description": "多供应商 + 角色系统的 AI 聊天；支持 Markdown/LaTeX/HTML(div) 渲染",
  "main": "index.js",
  "icon": "svg:icon.svg",
  "keyword": "ai",
  "apiVersion": 2,
  "ui": {
    "type": "iframe",
    "keepAlive": true
  },
  "background": {
    "autoStart": true
  },
  "requires": [
    "tauri:plugin:store|load",
    "tauri:plugin:store|get",
    "tauri:plugin:store|set",
    "tauri:plugin:store|save",
    "tauri:plugin:store|delete",
    "tauri:plugin:store|entries",
    "tauri:storage_get_all",
    "tauri:http_request",
    "tauri:http_request_stream",
    "tauri:http_request_stream_cancel",
    "tauri:plugin_pick_images",
    "tauri:plugin_images_write_base64",
    "tauri:plugin_images_read",
    "tauri:plugin_images_delete",
    "tauri:plugin:window|start_dragging",
    "tauri:plugin:clipboard-manager|write_text",
    "tauri:plugin:clipboard-manager|read_text"
  ]
}
